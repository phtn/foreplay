{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "strict": true,
    "noImplicitAny": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "esModuleInterop": true,
    "outDir": "dist",
    "rootDir": "scripts/src",
    "types": ["node"]
  },
  "include": ["scripts/src/**/*.ts"]
}
